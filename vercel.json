{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/pr-stats", "dest": "/api/pr-stats.js" },
    { "src": "/api/contribution", "dest": "/api/contribution.js" },
    { "src": "/api/languages", "dest": "/api/languages.js" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
